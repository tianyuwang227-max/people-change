{
  "name": "reverse-fate-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "cf:dev": "npm run build && wrangler pages dev dist",
    "db:migrate:local": "wrangler d1 execute DB --local --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute DB --remote --file=./migrations/0001_init.sql"
  },
  "dependencies": {
    "dayjs": "^1.11.13",
    "framer-motion": "^12.9.2",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.31",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
